<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>𓆩♡𓆪 My Digital Vanity 𓆩♡𓆪</title>
    <style>
        /* 🌸 THE PINK RETRO STYLING CODE 🌸 */
        body {
          background-color: #ffe4e1; /* Misty Rose Pink */
          background-image: radial-gradient(#ff69b4 15%, transparent 15%),
                            radial-gradient(#ff69b4 15%, transparent 15%);
          background-size: 16px 16px;
          background-position: 0 0, 8px 8px; /* Cute pixel tiny dot background */
          font-family: "Courier New", monospace;
          color: #ff1493;
          padding: 20px;
        }

        .desktop-header {
          text-align: center;
          background: #ffffff;
          border: 3px double #ff69b4;
          padding: 12px;
          margin-bottom: 30px;
          box-shadow: 4px 4px 0px #ff69b4;
        }

        h2 {
          font-size: 13px;
          background: #ff69b4;
          color: white;
          padding: 5px 10px;
          margin-top: 25px;
          display: inline-block;
          border: 2px solid #ff1493;
          border-bottom: none;
        }

        .scrolling-shelf {
          display: flex;
          overflow-x: auto;
          gap: 15px;
          padding: 15px;
          background: rgba(255, 255, 255, 0.85);
          border: 2px dashed #ff69b4;
          margin-bottom: 20px;
        }

        /* Retro Windows desktop pop-up cards */
        .product-card {
          flex: 0 0 170px;
          background: #ffffff;
          border: 2px solid #ff1493;
          box-shadow: 3px 3px 0px #ff69b4;
          padding: 8px;
          text-align: center;
        }

        .window-bar {
          background: linear-gradient(90deg, #ff1493, #ffb6c1);
          color: white;
          font-size: 9px;
          padding: 2px;
          margin-bottom: 8px;
          text-align: left;
          font-weight: bold;
        }

        .product-card img {
          width: 100%;
          height: 130px;
          object-fit: contain;
          background: #fff;
          border: 1px solid #ffb6c1;
        }

        .product-card h3 {
          font-size: 12px;
          margin: 8px 0 4px 0;
          white-space: nowrap;
          overflow: hidden;
          text-overflow: ellipsis;
        }

        .notes {
          font-size: 10px;
          color: #db7093;
          margin: 0;
          line-height: 1.2;
        }

        /* Mix and match layout styles */
        .recipe-box {
          background: #ffffff;
          border: 3px double #ff1493;
          padding: 15px;
          margin-bottom: 20px;
          box-shadow: 4px 4px 0px #ffb6c1;
        }

        .combo-zone {
          display: flex;
          align-items: center;
          gap: 10px;
          padding: 10px 0;
          overflow-x: auto;
        }

        .product-card.mini {
          flex: 0 0 110px;
          padding: 5px;
        }

        .product-card.mini img {
          height: 80px;
        }

        .product-card.mini h4 {
          font-size: 11px;
          margin: 4px 0;
        }

        .plus-sign {
          font-size: 24px;
          font-weight: bold;
          color: #ff1493;
        }
        
        .recipe-title {
          font-size: 12px;
          font-weight: bold;
          margin-bottom: 5px;
          color: #ff1493;
          text-decoration: underline;
        }
    </style>
</head>
<body>

  <div class="desktop-header">
